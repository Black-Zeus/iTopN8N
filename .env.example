# ==============================================================================
# iTop + n8n Integration Stack - ejemplo de entorno
# Copiar como .env y completar secretos antes de iniciar.
# ==============================================================================

# PostgreSQL
POSTGRES_DB=n8n_db
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=CHANGEME_pg_password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=CHANGEME_redis_password
REDIS_MAX_MEMORY=256mb

# n8n
N8N_VERSION=2.20.0
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EXTERNAL_PORT=5678
N8N_WEBHOOK_URL=http://localhost:8089/n8n/
N8N_EDITOR_BASE_URL=http://localhost:8089/n8n/
N8N_ENCRYPTION_KEY=CHANGEME_generate_with_openssl_rand_hex_32
N8N_EXECUTIONS_MODE=queue
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console

# NocoDB
NOCODB_JWT_SECRET=CHANGEME_generate_with_openssl_rand_hex_32
NOCODB_PUBLIC_URL=http://localhost:8089/nocodb
NOCODB_PORT=8080

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Nginx
NGINX_HTTP_PORT=8089

# Timezone
TIMEZONE=America/Santiago

# iTop reference values.
# These are not consumed directly by Docker Compose. Configure real credentials
# inside n8n credentials or the workflow SetBase as needed.
ITOP_BASE_URL=https://tu-itop-instance.example.com
ITOP_REST_PATH=/webservices/rest.php
ITOP_API_VERSION=1.3
ITOP_API_USER=api_user
ITOP_API_KEY=CHANGEME_itop_api_key_or_password
